# MyResty Framework - 环境配置文件
# 复制为 .env 并根据需要修改
# cp .env.example .env

# === 应用基础配置 ===
APP_HOST=localhost
APP_PORT=8080
APP_BASE_URL=
APP_CHARSET=UTF-8

# === MySQL 数据库 ===
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=myresty
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_CHARSET=utf8mb4
MYSQL_POOL_SIZE=100
MYSQL_IDLE_TIMEOUT=10000

# === Redis 缓存 ===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=100
REDIS_IDLE_TIMEOUT=10000

# === Session ===
SESSION_SECRET=
SESSION_COOKIE_NAME=myresty_session
SESSION_EXPIRES=86400
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict

# === 上传 ===
UPLOAD_PATH=/var/www/web/my-openresty/uploads
UPLOAD_MAX_SIZE=10
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,webp,pdf,doc,docx,xls,xlsx,zip

# === 验证码 ===
CAPTCHA_LENGTH=5
CAPTCHA_EXPIRES=300
CAPTCHA_WIDTH=120
CAPTCHA_HEIGHT=80

# === 日志 ===
LOG_LEVEL=2
LOG_DIR=/var/www/web/my-openresty/logs
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=5

# === 限流 ===
LIMIT_DEFAULT_RATE=100
LIMIT_DEFAULT_WINDOW=60
LIMIT_DEFAULT_BURST=20

# === 图片处理 ===
IMAGE_QUALITY=85
IMAGE_THUMBNAIL_SIZE=150
IMAGE_WEBP_QUALITY=80
